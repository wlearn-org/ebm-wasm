{
  "name": "@wlearn/ebm",
  "version": "0.1.0",
  "description": "InterpretML EBM (Explainable Boosting Machine) compiled to WebAssembly -- interpretable ML in browsers and Node.js",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/",
    "wasm/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --experimental-vm-modules test/test.js",
    "build": "bash scripts/build-wasm.sh",
    "verify": "bash scripts/verify-exports.sh"
  },
  "dependencies": {
    "@wlearn/types": "^0.1.0",
    "@wlearn/core": "^0.1.0"
  },
  "keywords": ["ebm", "explainable-boosting-machine", "interpretable-ml", "gam", "machine-learning", "wasm", "webassembly", "wlearn"],
  "author": "Anton Zemlyansky",
  "license": "MIT"
}
