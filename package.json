{
  "name": "@wlearn/ebm",
  "version": "0.1.0",
  "description": "InterpretML EBM (Explainable Boosting Machine) compiled to WebAssembly -- interpretable ML in browsers and Node.js",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "wasm/",
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node test/test.js",
    "build": "bash scripts/build-wasm.sh",
    "verify": "bash scripts/verify-exports.sh",
    "build:browser": "bash scripts/build-browser.sh"
  },
  "dependencies": {
    "@wlearn/core": "0.1.0",
    "@wlearn/types": "0.1.0"
  },
  "keywords": [
    "ebm",
    "explainable-boosting-machine",
    "interpretable-ml",
    "gam",
    "machine-learning",
    "wasm",
    "webassembly",
    "wlearn"
  ],
  "author": "Anton Zemlyansky",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.3",
    "playwright": "^1.58.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wlearn-org/ebm-wasm.git"
  }
}
